# ── OpenClaw Platform — Environment Variables ───────────────────
# Copy this file to .env and fill in your real keys
# NEVER commit .env to git

FINNHUB_KEY=your_finnhub_api_key_here
MASSIVE_KEY=your_massive_api_key_here

# Ports (optional — defaults shown)
PORT=3001
PORT_WM=3000

# ── Push Notifications ────────────────────────────────────────
# Generated automatically on first run (check server console output).
# Paste them here so they persist across deploys.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@costo.eu

# ── Discord Alerts ────────────────────────────────────────────
# Create a webhook in your Discord server:
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=
